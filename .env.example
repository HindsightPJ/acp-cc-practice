# 题库授权系统密钥模板
# 复制此文件为 .env 并填入真实值（仅作者机器需要）
# .env 不入库，由 .gitignore 排除

# 题库主密钥 K（Fernet key，base64 编码的 32 字节）
# 由 author_tools/keygen.py 生成
QUESTIONS_MASTER_KEY=

# Ed25519 私钥（64 字符 hex，用于签发注册码）
# 由 author_tools/keygen.py 生成
ED25519_PRIVATE_KEY=

# Ed25519 公钥（64 字符 hex，需同步复制到 license/public_key.py）
# 由 author_tools/keygen.py 生成
ED25519_PUBLIC_KEY=
